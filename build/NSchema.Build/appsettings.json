{
    "Build": {
        "ArtifactsDirectory": "artifacts",
        "TempDirectory": "temp",
        "Configuration": "Release",
        "ProjectFile": "src/NSchema/NSchema.csproj",
        "NuGetFeed": "https://api.nuget.org/v3/index.json"
    },
    "Logging": {
        "LogLevel": {
            "Default": "Debug"
        },
        "Console": {
            "FormatterOptions": {
